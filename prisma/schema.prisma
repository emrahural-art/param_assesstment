generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  HR_MANAGER
  HR_SPECIALIST
  HR_INTERN
}

enum CandidateStatus {
  ACTIVE
  ARCHIVED
  ANONYMIZED
}

enum ApplicationStage {
  NEW_APPLICATION
  SCREENING
  INTERVIEW
  ASSESSMENT
  OFFER
  HIRED
  REJECTED
}

enum ListingStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum QuestionType {
  MULTIPLE_CHOICE
  MULTI_SELECT
  TRUE_FALSE
  OPEN_ENDED
  PERSONALITY_SCALE
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum EmailTemplateType {
  POSITIVE
  NEGATIVE
  INVITATION
  TEST_INVITE
  CUSTOM
}

enum CommunicationStatus {
  QUEUED
  SENT
  DELIVERED
  OPENED
  FAILED
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String
  passwordHash   String
  role           UserRole        @default(HR_SPECIALIST)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  candidateNotes CandidateNote[]
}

model Candidate {
  id                String              @id @default(cuid())
  firstName         String
  lastName          String
  email             String              @unique
  phone             String?
  resumeUrl         String?
  cvData            Json?
  status            CandidateStatus     @default(ACTIVE)
  consentAt         DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  applications      Application[]
  assessmentResults AssessmentResult[]
  notes             CandidateNote[]
  communications    CommunicationLog[]
}

model Listing {
  id           String        @id @default(cuid())
  title        String
  description  String?
  requirements String?
  status       ListingStatus @default(DRAFT)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  applications Application[]
}

model Application {
  id          String           @id @default(cuid())
  candidateId String
  listingId   String
  stage       ApplicationStage @default(NEW_APPLICATION)
  appliedAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  candidate   Candidate        @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  listing     Listing          @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([candidateId, listingId])
}

model PipelineStage {
  id    String @id @default(cuid())
  name  String @unique
  order Int
  color String @default("#6366f1")
}

model Assessment {
  id              String             @id @default(cuid())
  title           String
  description     String?
  durationMinutes Int
  difficulty      Difficulty         @default(MEDIUM)
  isActive        Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  questions       Question[]
  results         AssessmentResult[]
}

model Question {
  id            String       @id @default(cuid())
  assessmentId  String
  text          String
  type          QuestionType @default(MULTIPLE_CHOICE)
  options       Json?
  correctAnswer String?
  points        Int          @default(1)
  order         Int
  assessment    Assessment   @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
}

model AssessmentResult {
  id           String     @id @default(cuid())
  candidateId  String
  assessmentId String
  score        Int?
  totalPoints  Int?
  answers      Json?
  violations   Json?
  startedAt    DateTime   @default(now())
  completedAt  DateTime?
  candidate    Candidate  @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@unique([candidateId, assessmentId])
}

model CandidateNote {
  id          String    @id @default(cuid())
  candidateId String
  userId      String
  content     String
  rating      Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailTemplate {
  id        String            @id @default(cuid())
  name      String
  type      EmailTemplateType
  subject   String
  body      String
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model CommunicationLog {
  id          String              @id @default(cuid())
  candidateId String
  templateId  String?
  subject     String
  body        String
  status      CommunicationStatus @default(QUEUED)
  sentAt      DateTime?
  openedAt    DateTime?
  createdAt   DateTime            @default(now())
  candidate   Candidate           @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}
