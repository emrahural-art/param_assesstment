generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SYSTEM_ADMIN
  ADMIN
  HR_MANAGER
  HR_SPECIALIST
  HR_INTERN
}

enum CandidateStatus {
  ACTIVE
  ARCHIVED
  ANONYMIZED
}

enum ApplicationStage {
  NEW_APPLICATION
  SCREENING
  INTERVIEW
  ASSESSMENT
  OFFER
  HIRED
  REJECTED
}

enum ListingStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum QuestionType {
  MULTIPLE_CHOICE
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum EmailTemplateType {
  POSITIVE
  NEGATIVE
  INVITATION
  TEST_INVITE
  CUSTOM
}

enum CommunicationStatus {
  QUEUED
  SENT
  DELIVERED
  OPENED
  FAILED
}

enum Company {
  PARAM
  PARAMTECH
  FINROTA
  KREDIM
  UNIVERA
}

model User {
  id               String          @id @default(cuid())
  email            String          @unique
  name             String
  passwordHash     String?
  role             UserRole        @default(HR_SPECIALIST)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  candidateNotes   CandidateNote[]
  sentLoginInvites LoginInvite[]   @relation("UserLoginInvites")
}

model LoginInvite {
  id          String   @id @default(cuid())
  email       String   @unique
  role        UserRole
  invitedById String
  invitedBy   User     @relation("UserLoginInvites", fields: [invitedById], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model Candidate {
  id                String              @id @default(cuid())
  firstName         String
  lastName          String
  email             String              @unique
  phone             String?
  resumeUrl         String?
  cvData            Json?
  company           Company?
  position          String?
  department        String?
  status            CandidateStatus     @default(ACTIVE)
  consentAt         DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  applications      Application[]
  assessmentResults AssessmentResult[]
  notes             CandidateNote[]
  communications    CommunicationLog[]
  examInvites       ExamInvite[]
}

model Listing {
  id           String        @id @default(cuid())
  title        String
  description  String?
  requirements String?
  status       ListingStatus @default(DRAFT)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  applications Application[]
}

model Application {
  id          String           @id @default(cuid())
  candidateId String
  listingId   String
  stage       ApplicationStage @default(NEW_APPLICATION)
  appliedAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  candidate   Candidate        @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  listing     Listing          @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([candidateId, listingId])
}

model PipelineStage {
  id    String @id @default(cuid())
  name  String @unique
  order Int
  color String @default("#6366f1")
}

model Assessment {
  id              String             @id @default(cuid())
  title           String
  description     String?
  durationMinutes Int
  difficulty      Difficulty         @default(MEDIUM)
  isActive        Boolean            @default(true)
  scoringConfig   Json?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  questions       Question[]
  results         AssessmentResult[]
  invites         ExamInvite[]
}

model Question {
  id            String       @id @default(cuid())
  assessmentId  String
  text          String
  type          QuestionType @default(MULTIPLE_CHOICE)
  options       Json?
  correctAnswer String?
  points        Int          @default(1)
  order         Int
  category      String?
  tags          String[]     @default([])
  imageUrl      String?
  assessment    Assessment   @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
}

model AssessmentResult {
  id             String     @id @default(cuid())
  candidateId    String
  assessmentId   String
  score          Int?
  totalPoints    Int?
  answers        Json?
  violations     Json?
  categoryScores Json?
  level          String?
  jobFitResults  Json?
  dimensionResults Json?
  startedAt      DateTime   @default(now())
  completedAt    DateTime?
  candidate      Candidate  @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  assessment     Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@unique([candidateId, assessmentId])
}

model ExamInvite {
  id           String       @id @default(cuid())
  assessmentId String
  candidateId  String
  token        String       @unique @default(cuid())
  status       InviteStatus @default(PENDING)
  sentAt       DateTime?
  expiresAt    DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime     @default(now())
  assessment   Assessment   @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  candidate    Candidate    @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([candidateId, assessmentId])
}

enum InviteStatus {
  PENDING
  STARTED
  COMPLETED
  EXPIRED
}

model CandidateNote {
  id          String    @id @default(cuid())
  candidateId String
  userId      String
  content     String
  rating      Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailTemplate {
  id        String            @id @default(cuid())
  name      String
  type      EmailTemplateType
  subject   String
  body      String
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model CommunicationLog {
  id          String              @id @default(cuid())
  candidateId String
  templateId  String?
  subject     String
  body        String
  status      CommunicationStatus @default(QUEUED)
  sentAt      DateTime?
  openedAt    DateTime?
  createdAt   DateTime            @default(now())
  candidate   Candidate           @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  description String?
  enabled     Boolean  @default(true)
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  userName  String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())
}

model AppLog {
  id        String   @id @default(cuid())
  level     String
  message   String
  context   String?
  data      Json?
  createdAt DateTime @default(now())
}
